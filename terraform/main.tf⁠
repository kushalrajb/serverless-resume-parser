provider "aws" {
  region = "us-east-1"
}

# 1. S3 Bucket configured to match workflow import expectations
resource "aws_s3_bucket" "resumes" {
  bucket = "resume-parser-uploads-dev-portfolio"
}

# 2. DynamoDB Table for Storing Parsed Matrix Data
resource "aws_dynamodb_table" "parsed_resumes" {
  name         = "ParsedResumes"
  billing_mode = "PAY_PER_REQUEST"
  hash_key     = "ResumeID"

  attribute {
    name = "ResumeID"
    type = "S"
  }
}

# 3. IAM Execution Role for Lambda Function
resource "aws_iam_role" "lambda_role" {
  name = "resume-parser-lambda-role-dev"

  assume_role_policy = jsonencode({
    Version = "2012-10-17",
    Statement = [{
      Action    = "sts:AssumeRole",
      Effect    = "Allow",
      Principal = { Service = "lambda.amazonaws.com" }
    }]
  })
}

# 4. IAM Policy allowing Lambda to interact with S3 and DynamoDB
resource "aws_iam_role_policy" "lambda_policy" {
  name = "resume-parser-lambda-policy"
  role = aws_iam_role.lambda_role.id

  policy = jsonencode({
    Version = "2012-10-17",
    Statement = [
      {
        Action   = ["s3:GetObject", "s3:ListBucket"],
        Effect   = "Allow",
        Resource = ["${aws_s3_bucket.resumes.arn}", "${aws_s3_bucket.resumes.arn}/*"]
      },
      {
        Action   = ["dynamodb:PutItem", "dynamodb:GetItem"],
        Effect   = "Allow",
        Resource = "${aws_dynamodb_table.parsed_resumes.arn}"
      }
    ]
  })
}

# 5. Core Lambda Serverless Compute Resource
resource "aws_lambda_function" "parser" {
  filename      = "../lambda/parser.zip"
  function_name = "resume-parser-dev"
  role          = aws_iam_role.lambda_role.arn
  handler       = "parser.lambda_handler"
  runtime       = "python3.12"

  environment {
    variables = {
      DYNAMODB_TABLE = aws_dynamodb_table.parsed_resumes.name
    }
  }
}

# 6. API Gateway (V2 HTTP API) Front-End
resource "aws_apigatewayv2_api" "api" {
  name          = "resume-parser-api-dev"
  protocol_type = "HTTP"
}

# 7. CloudWatch Log Group Containers Expected by Workflow
resource "aws_cloudwatch_log_group" "lambda_logs" {
  name              = "/aws/lambda/resume-parser-dev"
  retention_in_days = 7
}

resource "aws_cloudwatch_log_group" "api_logs" {
  name              = "/aws/apigateway/resume-parser-dev"
  retention_in_days = 7
}
